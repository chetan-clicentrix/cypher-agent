# PicoVoice API Key (for Wake Word Detection)
PICOVOICE_API_KEY=your_picovoice_key

# Google Gemini API Key (Recommended)
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_key

# NVIDIA NIM API Key (for STT and specialized LLMs)
# Get key: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_key

# OpenAI & Anthropic (Optional)
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# Local LLM Endpoint (Ollama)
OLLAMA_ENDPOINT=http://localhost:11434

# Default LLM Strategy: 'ollama' | 'nvidia' | 'gemini' | 'auto'
DEFAULT_LLM=auto

# Tavily API Key (for Search Capabilities)
TAVILY_API_KEY=your_tavily_key
